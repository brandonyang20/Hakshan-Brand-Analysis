# ── Instagram Graph API ─────────────────────────────────────────────────────
# Long-lived token (valid 60 days). Refresh by re-calling the exchange endpoint.
# Setup guide:
#   1. developers.facebook.com → Create App → Business
#   2. Add product: Instagram Graph API
#   3. Connect the Facebook Page linked to @hakshan_ Instagram account
#   4. Graph Explorer → select your App → Generate Access Token
#      Grant: instagram_basic, pages_read_engagement, pages_show_list
#   5. Exchange for long-lived token:
#      GET https://graph.facebook.com/v19.0/oauth/access_token
#        ?grant_type=fb_exchange_token
#        &client_id={APP_ID}
#        &client_secret={APP_SECRET}
#        &fb_exchange_token={SHORT_LIVED_TOKEN}
#   6. Copy the long-lived token below and set it in Railway env vars
INSTAGRAM_ACCESS_TOKEN=

# ── Facebook Graph API ──────────────────────────────────────────────────────
# Page access token (same long-lived token works for both IG and FB page).
# FACEBOOK_PAGE_ID: the numeric ID from your Facebook Page URL or Graph Explorer.
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── Admin endpoint ──────────────────────────────────────────────────────────
# Protects POST /api/competitors/social — set any secret string.
# Example: openssl rand -hex 16
ADMIN_TOKEN=your-secret-token-here
